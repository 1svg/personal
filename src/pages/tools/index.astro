---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { Icon } from 'astro-icon/components'

const tools = [
  {
    href: '/tools/budget',
    title: 'Budget Tool',
    icon: 'lucide:wallet',
    description:
      'Manage your monthly budget, calculate free allocation and distribute envelopes.',
  },
]
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Tools" />
  <Breadcrumbs items={[{ label: 'Tools', icon: 'lucide:wrench' }]} />

  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-1">
      <h1 class="text-2xl font-semibold">Tools</h1>
      <p class="text-foreground/60 text-sm">
        A selection of handy tools I use or build.
      </p>
    </div>

    <ul class="flex flex-col gap-2">
      {
        tools.map((tool) => (
          <li>
            <Link
              href={tool.href}
              class="hover:bg-accent/10 text-foreground/80 hover:text-foreground block rounded-lg p-4 transition-colors"
            >
              <span class="inline-flex items-center gap-2 font-medium">
                <Icon name={tool.icon} class="size-4" />
                <span>{tool.title}</span>
              </span>

              <p class="text-foreground/60 mt-1 text-sm">{tool.description}</p>
            </Link>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
