---
import Breadcrumbs from '@/components/shared/breadcrumbs.astro'
import PageHead from '@/components/shared/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getEntry } from 'astro:content'
import Finance from '../../../components/tools/finance'

const tool = await getEntry('tools', 'finance')
if (!tool) throw new Error('Outil introuvable')
const { name, description, icon } = tool.data
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title={name} description={description} />

  <Breadcrumbs
    items={[
      { label: 'Outils', href: '/tools', icon: 'lucide:wrench' },
      { label: name, icon: icon ?? 'lucide:tool' },
    ]}
  />

  <Finance client:load />
</Layout>
