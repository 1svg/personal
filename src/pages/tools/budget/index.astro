---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import Layout from '@/layouts/layout.astro'
import { Icon } from 'astro-icon/components'
import { getEntry } from 'astro:content'

const tool = await getEntry('tools', 'budget')
if (!tool) throw new Error('Outil introuvable')
const { name, description, icon } = tool.data
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title={name} description={description} />

  <Breadcrumbs
    items={[
      { label: 'Outils', href: '/tools', icon: 'lucide:wrench' },
      { label: name, icon: icon ?? 'lucide:tool' },
    ]}
  />

  <div class="flex flex-col gap-6">
    <Card>
      <CardHeader>
        <CardTitle>{name}</CardTitle>
      </CardHeader>

      <!-- reste du JSX inchangé -->
      <CardContent>
        <div class="bg-muted/20 space-y-4 rounded-md p-3">
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="space-y-2">
              <label
                for="income-input"
                class="text-muted-foreground text-xs font-medium"
              >
                Revenus totaux
              </label>
              <input
                id="income-input"
                type="number"
                min="0"
                step="0.01"
                placeholder="2500"
                class="border-border bg-background w-full rounded border p-2 text-sm"
              />
            </div>

            <div class="space-y-2">
              <label
                for="fixed-input"
                class="text-muted-foreground text-xs font-medium"
              >
                Charges fixes
              </label>
              <input
                id="fixed-input"
                type="number"
                min="0"
                step="0.01"
                placeholder="1200"
                class="border-border bg-background w-full rounded border p-2 text-sm"
              />
            </div>
          </div>
        </div>

        <div
          class="border-border/50 mt-4 grid grid-cols-1 gap-4 border-t pt-4 md:grid-cols-2"
        >
          <div>
            <p class="text-muted-foreground text-xs font-medium">
              Allocation libre
            </p>
            <p id="free-output" class="mt-1 font-mono text-lg font-semibold">
              0,00 €
            </p>
          </div>

          <div>
            <p class="text-muted-foreground text-xs font-medium">
              Reste non alloué
            </p>
            <p
              id="remaining-output"
              class="mt-1 font-mono text-lg font-semibold"
            >
              0,00 €
            </p>
          </div>
        </div>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
        >
          <CardTitle>Enveloppes</CardTitle>

          <div class="flex flex-wrap gap-2">
            <button
              id="add-envelope"
              class="border-border bg-background hover:bg-muted rounded border px-3 py-1.5 text-sm transition-colors"
              type="button"
            >
              <span class="flex items-center gap-1.5">
                <Icon name="lucide:plus" class="size-3.5" />
                Ajouter une enveloppe
              </span>
            </button>

            <button
              id="reset-form"
              class="border-border bg-background hover:bg-muted rounded border px-3 py-1.5 text-sm transition-colors"
              type="button"
            >
              <span class="flex items-center gap-1.5">
                <Icon name="lucide:rotate-ccw" class="size-3.5" />
                Réinitialiser
              </span>
            </button>
          </div>
        </div>
      </CardHeader>

      <CardContent>
        <div id="envelopes-list" class="flex flex-col gap-3">
          <div
            id="empty-envelopes"
            class="border-border text-muted-foreground rounded-md border border-dashed px-4 py-8 text-center text-sm"
          >
            Aucune enveloppe ajoutée. Cliquez sur "Ajouter une enveloppe" pour
            commencer.
          </div>
        </div>
      </CardContent>
    </Card>
  </div>
</Layout>

<script>
  // ... ton script inchangé
</script>
