---
import AuthorCard from '@/components/author-card.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getAllAuthors } from '@/lib/data-utils'

const authors = await getAllAuthors()
const author = authors[0]
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />

  <div class="flex flex-col gap-3">
    <section class="rounded-lg border p-6">
      <h3 class="text-3xl leading-none font-medium">1svg</h3>
      <p class="text-muted-foreground text-sm">
        /wʌn ɛs viː dʒiː/ &bull; <span class="font-medium">noun</span>
      </p>
    </section>
    {author && <AuthorCard author={author} />}
  </div>
</Layout>
