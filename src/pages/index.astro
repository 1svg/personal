---
import AuthorCard from '@/components/cards/author-card.astro'
import WorkshopCard from '@/components/cards/workshop-card.astro'
import Link from '@/components/shared/link.astro'
import PageHead from '@/components/shared/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/layout.astro'
import { getCollection, getEntry } from 'astro:content'

const author = await getEntry('user', '1svg')
if (!author) throw new Error('Auteur introuvable')

const tools = await getCollection('workshop', ({ data }) => !data.draft)
tools.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const recentTools = tools.slice(0, 3)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Accueil" />

  <AuthorCard author={author} />

  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Workshop</h2>
    <ul class="flex flex-col gap-4">
      {
        recentTools.map((tool) => (
          <li>
            <WorkshopCard tool={tool} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/workshop"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        Voir le workshop <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
