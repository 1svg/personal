---
import { Button } from '@/components/ui/button'
import { Icon } from 'astro-icon/components'
---

<Button
  id="theme-toggle"
  variant="ghost"
  size="icon"
  title="Toggle theme"
  className="-my-2 -me-2 size-8"
>
  <Icon name="lucide:sun" class="size-4 dark:hidden" />
  <Icon name="lucide:moon" class="absolute hidden size-4 dark:block" />
  <span class="sr-only">Toggle theme</span>
</Button>

<script is:inline data-astro-rerun>
  ;(() => {
    const stored = localStorage?.getItem('theme') ?? ''
    const theme = ['dark', 'light'].includes(stored)
      ? stored
      : window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light'

    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem('theme', theme)
  })()
</script>

<script>
  const el = document.documentElement

  function applyTheme(theme: string) {
    el.classList.add('[&_*]:transition-none')
    el.setAttribute('data-theme', theme)
    window.getComputedStyle(el).getPropertyValue('opacity')
    requestAnimationFrame(() => el.classList.remove('[&_*]:transition-none'))
    localStorage.setItem('theme', theme)
  }

  function handleToggleClick() {
    const newTheme = el.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
    applyTheme(newTheme)
  }

  function initThemeToggle() {
    document
      .getElementById('theme-toggle')
      ?.addEventListener('click', handleToggleClick)
  }

  initThemeToggle()

  document.addEventListener('astro:after-swap', () => {
    applyTheme(localStorage.getItem('theme') ?? 'light')
    initThemeToggle()
  })
</script>
