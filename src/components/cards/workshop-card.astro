---
import Link from '@/components/shared/link.astro'
import { Icon } from 'astro-icon/components'
import type { CollectionEntry } from 'astro:content'

interface Props {
  tool: CollectionEntry<'workshop'>
}

const { tool } = Astro.props
---

<div
  class="hover:bg-muted/50 rounded-xl border p-4 transition-colors duration-300 ease-in-out"
>
  <Link href={`/workshop/${tool.id}`} class="flex items-center gap-4">
    {
      tool.data.icon && (
        <Icon
          name={tool.data.icon}
          class="text-muted-foreground size-8 shrink-0"
        />
      )
    }
    <div class="grow">
      <h3 class="mb-1 text-lg font-medium">{tool.data.name}</h3>
      <p class="text-muted-foreground text-sm">{tool.data.description}</p>
    </div>
  </Link>
</div>
